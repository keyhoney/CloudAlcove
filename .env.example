# 로컬: vite proxy가 /ws → localhost:8787 로 전달
# 프로덕션: Worker 배포 URL (wss://...)
VITE_SIGNALING_URL=

# TURN 서버 (선택 — Metered.ca 등 무료 플랜)
# 세 값을 모두 설정하면 P2P 연결 실패율이 줄어듭니다.
VITE_TURN_URL=turn:global.relay.metered.ca:443
VITE_TURN_USERNAME=your-metered-username
VITE_TURN_CREDENTIAL=your-metered-credential

# 또는 ICE 서버 JSON 배열로 직접 지정 (위 TURN 변수보다 우선)
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:...","username":"...","credential":"..."}]
